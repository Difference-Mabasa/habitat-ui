# Habitat UI — environment variables
# Copy to .env (gitignored) and fill in real values for local dev.

# Override the default API base. In dev, leave blank to use the Vite /api proxy
# (which forwards to http://localhost:8080). In prod, set to the deployed
# habitat-api origin including /api/v1.
# VITE_API_BASE_URL=https://api.habitat.co.za/api/v1

# Google Maps Places API key. Used by AddressLookup (and later by the /browse
# and /property-detail map views). Injected into index.html at build time via
# Vite %placeholder% substitution.
#
# This key is meant to be public in the built bundle — security comes from
# HTTP-referrer restrictions configured in Google Cloud Console (allowlist
# habitat.co.za and localhost:5173). Never commit the actual value to git.
#
# When unset, AddressLookup falls back to Nominatim (OpenStreetMap) — slower
# and patchier SA suburb data, but the form remains functional.
VITE_GOOGLE_MAPS_KEY=
