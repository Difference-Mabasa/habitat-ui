# Backroom UI (habitat-ui repo) — environment variables
# Copy to .env (gitignored) and adjust as needed.

# Override the default API base. In dev, leave blank to use the Vite /api proxy
# (which forwards to http://localhost:8080). In prod, set to the deployed
# backroom-api origin including /api/v1.
# VITE_API_BASE_URL=https://api.backroom.example.com/api/v1
